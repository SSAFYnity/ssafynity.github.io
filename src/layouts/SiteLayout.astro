  },
  '/join/premium': {
    title: '정회원 안내 | SSAFYnity',
    description: 'SSAFYnity 정회원 혜택과 신청 방법, 추천 대상을 확인하세요.',
  },
  '/join/partnership': {
    title: '후원·제휴 문의 | SSAFYnity',
    description: 'SSAFYnity와의 후원 및 제휴 협력 방식, 기대 효과, 문의 절차를 안내합니다.',
  },
  '/community/faq': {
    title: 'FAQ | SSAFYnity',
    description: '가입, 행사, 동아리, 커뮤니티 관련 자주 묻는 질문을 확인하세요.',
  },
  '/community/sns': {
    title: '공식 채널 | SSAFYnity',
    description: 'SSAFYnity 공식 메일과 SNS, 커뮤니티 채널 이용 방법을 안내합니다.',
  },
  '/privacy': {
    title: '개인정보처리방침 | SSAFYnity',
