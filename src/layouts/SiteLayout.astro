  },
  '/about/story': {
    title: '동문회 소개 | SSAFYnity',
    description: 'SSAFYnity의 시작과 운영 철학, 연혁과 동문 분포를 소개합니다.',
  },
  '/about/values': {
    title: '가치관 | SSAFYnity',
    description: 'SSAFYnity가 추구하는 연결, 성장, 나눔의 가치를 소개합니다.',
  },
  '/about/partners': {
    title: '후원·협력사 | SSAFYnity',
    description: 'SSAFYnity와 함께하는 후원사와 협력 파트너를 확인하세요.',
