---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Footer from '~/components/Footer.astro'
import Navbar from '~/components/Navbar.astro'

interface Props {
  pathname: string
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
}

const metaByPath: Record<string, { title: string; description: string }> = {
