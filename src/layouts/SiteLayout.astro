    description: 'SSAFYnity 운영진 지원 자격, 활동 방식, 혜택과 모집 정보를 확인하세요.',
  },
  '/events/introduce': {
    title: '행사 소개 | SSAFYnity',
    description: 'SSAFYnity 정기 행사와 상시 행사 운영 방식, 참여 자격을 안내합니다.',
  },
  '/events/upcoming': {
    title: '행사 일정 | SSAFYnity',
    description: '올해 예정된 SSAFYnity 행사 일정과 접수 상태를 확인하세요.',
  },
  '/events/archive': {
    title: '역대 행사 | SSAFYnity',
    description: '지금까지 진행된 SSAFYnity 행사 기록을 연도별로 살펴보세요.',
  },
  '/clubs': {
    title: '정식 동아리 | SSAFYnity',
    description: 'SSAFYnity 공식 소속 동아리 목록과 활동 정보를 확인하세요.',
  },
  '/clubs/pre': {
    title: '예비 동아리 | SSAFYnity',
    description: '함께할 동문을 찾는 예비 동아리 모집 현황을 확인하세요.',
  },
  '/clubs/intro': {
    title: '동아리 소개 | SSAFYnity',
    description: 'SSAFYnity 동아리 제도와 등록 자격, 유지 조건, 혜택을 안내합니다.',
  },
  '/clubs/apply': {
    title: '동아리 신청 | SSAFYnity',
