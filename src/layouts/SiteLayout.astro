  },
}

const {
  pathname,
  title,
  description,
  canonical = `https://ssafynity.github.io${pathname}`,
  noindex = false,
} = Astro.props

const defaultMeta = metaByPath[pathname]
const resolvedTitle = title ?? defaultMeta?.title
const resolvedDescription = description ?? defaultMeta?.description
---

<BaseLayout
  title={resolvedTitle}
  description={resolvedDescription}
  canonical={canonical}
  noindex={noindex}
>
  <div class="flex flex-col min-h-screen">
    <Navbar pathname={pathname} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </div>
</BaseLayout>
