---
import Card from '~/components/Card.astro'
import Container from '~/components/Container.astro'
import HeroLabel from '~/components/HeroLabel.astro'
import Kicker from '~/components/Kicker.astro'
import LucideIcon from '~/components/LucideIcon.astro'
import SiteLayout from '~/layouts/SiteLayout.astro'
import { siteData } from '@/data/siteData'

const pathname = '/join/premium'

const whyItems = [
  {
    icon: 'calendar-days',
    title: ['행사를 빠지지 않고', '참여하는 분'],
    desc: '정기행사를 즐겨 찾는다면, 무료 입장 혜택 하나만으로도 연회비 이상의 가치를 가져갈 수 있어요.',
  },
  {
    icon: 'users',
    title: ['동문 인연을', '소중히 여기는 분'],
    desc: '같은 SSAFY 출신과 더 깊이 교류하고 싶다면, 정회원 전용 소통망이 그 연결고리가 됩니다.',
  },
  {
    icon: 'star',
    title: ['동문회를 함께', '만들어가고 싶은 분'],
    desc: 'SSAFYnity가 더 좋아지길 바라고, 그 과정에 직접 기여하고 싶다면 정회원으로 함께해 주세요.',
  },
] as const

const benefitItems = [
  { icon: 'crown', title: '정기행사 최우선 접수', desc: ['모든 정기행사를', '일반회원보다 먼저 접수할 수 있습니다.'] },
  { icon: 'star', title: '정기행사 무료 입장', desc: ['연 2회 정기행사를', '무료로 참여할 수 있습니다.'] },
  { icon: 'message-circle', title: '정회원 전용 소통망', desc: ['정회원 전용 채널에서', '더 가까이 소통하고 교류합니다.'] },
  { icon: 'package', title: '전용 굿즈 연 1회', desc: ['정회원 전용 특별 굿즈를', '연 1회 받을 수 있습니다.'] },
  { icon: 'bell', title: '모든 공지 최우선 수신', desc: ['동문회 소식과 공지를', '일반회원보다 먼저 받아볼 수 있습니다.'] },
  { icon: 'calendar-check-2', title: '행사 일정 선택권', desc: ['일부 행사의 날짜 등 세부 사항에', '대한 선택 옵션이 제공됩니다.'] },
] as const

const applySteps = ['동문회 가입', '정회원 신청', '회비 납부', '가입 완료'] as const
---

<SiteLayout pathname={pathname}>
  <div class="flex flex-col">
    <section class="bg-white pt-20 sm:pt-24 pb-12 sm:pb-14 lg:pt-28 lg:pb-20 border-b border-slate-100">
      <Container maxWidth="3xl">
        <div class="astro-reveal">
          <HeroLabel>동문회 정회원</HeroLabel>
          <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight leading-[1.2] text-slate-900 mb-2">
            정회원 안내
          </h1>
          <p class="text-xl md:text-2xl font-black text-blue-600 mb-4">SSAFYnity Premium Membership</p>
          <p class="text-sm text-slate-500 leading-relaxed break-keep max-w-xl">
            정회원은 연회비를 납부한 공식 정회원으로, SSAFYnity의 운영과 행사 진행에 큰 힘이 됩니다.
          </p>
        </div>
      </Container>
    </section>

    <section class="bg-slate-50 py-12 sm:py-14 lg:py-20">
      <Container maxWidth="3xl" className="flex flex-col gap-12 sm:gap-16">
        <div class="astro-reveal">
          <Kicker className="text-blue-600 mb-2">이런 분께 권해요</Kicker>
          <p class="text-sm text-slate-500 leading-relaxed break-keep mb-6">
            아래 중 하나라도 해당된다면, 정회원이 딱 맞습니다.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {whyItems.map((item) => (
              <Card className="p-5 lg:p-6 flex flex-row sm:flex-col items-start gap-4 sm:gap-3">
                <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
                  <LucideIcon name={item.icon} size={20} className="w-5 h-5 text-blue-600" />
                </div>
                <div class="flex flex-col gap-2 sm:gap-0">
                  <p class="text-sm font-extrabold text-slate-900 leading-snug">
                    <span class="text-slate-400 font-semibold">{item.title[0]}</span><span class="block">{item.title[1]}</span>
                  </p>
                  <p class="text-xs text-slate-500 leading-relaxed break-keep sm:mt-2">{item.desc}</p>
                </div>
              </Card>
            ))}
          </div>
        </div>

        <div class="astro-reveal" data-reveal-delay="50">
          <Kicker className="text-blue-600 mb-4">일반회원 vs 정회원</Kicker>
          <Card className="p-0 overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-left">
                <thead>
                  <tr class="border-b border-slate-100">
                    <th class="px-3 py-3 sm:px-6 sm:py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 w-1/3">항목</th>
                    <th class="px-3 py-3 sm:px-6 sm:py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 w-1/3">
                      {siteData.membership.regular.title}
                    </th>
                    <th class="px-3 py-3 sm:px-6 sm:py-4 text-[10px] font-black uppercase tracking-widest text-blue-500 bg-blue-50/40 w-1/3">
                      {siteData.membership.premium.title}
                    </th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-xs font-black text-slate-700">회비</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm text-slate-500">{siteData.membership.regular.fee}</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm font-bold text-slate-700 bg-blue-50/20">{siteData.membership.premium.fee}</td>
                  </tr>
                  <tr>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-xs font-black text-slate-700">가입 조건</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm text-slate-500">{siteData.membership.regular.desc}</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm text-slate-500 bg-blue-50/20">동문회 가입 승인된 일반회원</td>
                  </tr>
                  <tr>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-xs font-black text-slate-700">행사 접수</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm text-slate-500">일반 선착순</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm font-bold text-blue-600 bg-blue-50/20">최우선 접수</td>
                  </tr>
                  <tr>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-xs font-black text-slate-700">정기행사 참가비</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm text-slate-500">유료</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm font-bold text-blue-600 bg-blue-50/20">무료</td>
                  </tr>
                  <tr>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-xs font-black text-slate-700">공지 수신</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm text-slate-500">기본 안내</td>
                    <td class="px-3 py-3 sm:px-6 sm:py-4 text-sm font-bold text-blue-600 bg-blue-50/20">최우선 수신</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </Card>
        </div>

        <div class="astro-reveal" data-reveal-delay="100">
          <Kicker className="text-blue-600 mb-4">정회원 혜택</Kicker>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {benefitItems.map((item) => (
              <Card className="p-5 flex items-start gap-4">
                <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
                  <LucideIcon name={item.icon} size={18} className="w-[18px] h-[18px] text-blue-600" />
                </div>
                <div>
                  <p class="text-sm font-extrabold text-slate-900 mb-1">{item.title}</p>
                  <p class="text-xs text-slate-500 leading-snug break-keep">
                    <span class="block">{item.desc[0]}</span><span class="block">{item.desc[1]}</span>
                  </p>
                </div>
              </Card>
            ))}
          </div>
        </div>

        <div class="astro-reveal" data-reveal-delay="150">
          <Kicker className="text-blue-600 mb-4">상시 신청</Kicker>
          <Card className="p-6 lg:p-8 flex flex-col gap-6">
            <p class="text-sm text-slate-600 leading-relaxed break-keep">
              정회원은 <strong class="text-slate-800">동문회 가입 승인 이후</strong> 언제든지 신청할 수 있습니다.
              별도의 모집 기간 없이 상시로 운영됩니다.
            </p>

            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-1.5">
              {applySteps.map((step, index) => (
                <div class="flex items-center gap-1.5 flex-1">
                  <div class="flex flex-col items-center gap-0.5 flex-1 text-center px-3 py-3 rounded-xl bg-slate-50">
                    <span class="text-[9px] font-black uppercase tracking-widest text-blue-400 mb-1">STEP {index + 1}</span>
                    <span class="text-xs font-extrabold text-slate-700">{step}</span>
                  </div>
                  {index < applySteps.length - 1 && (
                    <LucideIcon name="chevron-right" size={16} className="hidden sm:block w-4 h-4 text-slate-300 shrink-0" />
                  )}
                </div>
              ))}
            </div>

            <div class="flex items-center justify-between px-5 py-4 rounded-2xl bg-blue-50">
              <p class="text-sm font-extrabold text-slate-800">연회비</p>
              <p class="text-sm font-black text-blue-600">{siteData.membership.premium.fee}</p>
            </div>

            <p class="text-xs text-slate-400 text-center">
              하단 버튼에서 바로 정회원 신청을 진행할 수 있습니다.
            </p>
          </Card>
        </div>
      </Container>
    </section>

    <section class="bg-blue-950 py-14 sm:py-16">
      <Container maxWidth="3xl" className="flex flex-col items-center text-center gap-6">
        <h2 class="text-xl md:text-2xl font-extrabold text-white leading-snug">정회원으로 SSAFYnity를<br class="sm:hidden" /> 함께 만들어주세요.</h2>
        <a
          href={siteData.forms.regular}
          target="_blank"
          rel="noopener noreferrer"
          data-track-event="click_regular_membership_apply"
          data-track-params={JSON.stringify({
            cta_label: '정회원 신청하기',
            destination_url: siteData.forms.regular,
          })}
          class="w-full inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full bg-white text-blue-950 text-base font-black tracking-wide hover:bg-blue-100 transition-colors shadow-lg shadow-blue-950/30"
        >
          정회원 신청하기
          <LucideIcon name="external-link" size={16} className="w-4 h-4" />
        </a>
        <p class="text-xs text-blue-300">새 탭에서 신청 폼이 열립니다</p>
      </Container>
    </section>
  </div>
</SiteLayout>
