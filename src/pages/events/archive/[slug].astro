          </div>
        </Container>
      </section>
    </div>
  )}

  {event && (
    <script is:inline define:vars={{ eventData: event, relatedRecord }}>
      (() => {
        const getStatus = (targetEvent) => {
          const now = new Date();
          const today = new Date(now);
          today.setHours(0, 0, 0, 0);

          const toDate = (value) => {
            const date = new Date(value);
            date.setHours(0, 0, 0, 0);
            return date;
          };

          const eventStartDate = toDate(targetEvent.eventDate.start);
          const eventEndDate = toDate(targetEvent.eventDate.end || targetEvent.eventDate.start);

          if (today > eventEndDate) return 'past';

          if (today >= eventStartDate && today <= eventEndDate) {
            if (!targetEvent.eventDate.startTime) return 'today-ongoing';

            const [startHour, startMinute] = targetEvent.eventDate.startTime.split(':').map(Number);
            const eventStart = new Date(targetEvent.eventDate.start);
            eventStart.setHours(startHour, startMinute, 0, 0);

            const endDate = new Date(targetEvent.eventDate.end || targetEvent.eventDate.start);
            const [endHour, endMinute] = (targetEvent.eventDate.endTime || '23:59').split(':').map(Number);
            endDate.setHours(endHour, endMinute, 0, 0);

            if (now < eventStart) return 'today-upcoming';
            if (now <= endDate) return 'today-ongoing';
            return 'past';
          }

          if (!targetEvent.recruitDate) return targetEvent.audience === 'operator' ? 'no-recruit' : 'planning';

          const recruitStart = toDate(targetEvent.recruitDate.start);
          const recruitEnd = toDate(targetEvent.recruitDate.end || targetEvent.recruitDate.start);

          if (today < recruitStart) return 'before-recruit';
          if (today <= recruitEnd) return 'recruiting';
          return 'recruit-closed';
        };

        const isRecruitSoon = (targetEvent, status) => {
          if (status !== 'before-recruit' || !targetEvent.recruitDate) return false;

          const today = new Date();
          today.setHours(0, 0, 0, 0);

          const recruitStart = new Date(targetEvent.recruitDate.start);
          recruitStart.setHours(0, 0, 0, 0);

          return (recruitStart.getTime() - today.getTime()) / 86400000 <= 14;
        };

        const getActionState = (targetEvent, status) => {
          const toDate = (value) => {
            const date = new Date(value);
            date.setHours(0, 0, 0, 0);
            return date;
          };

          const today = new Date();
          today.setHours(0, 0, 0, 0);
          const diffDay = (value) => Math.ceil((toDate(value).getTime() - today.getTime()) / 86400000);

          const dday =
            status === 'before-recruit' && targetEvent.recruitDate
              ? diffDay(targetEvent.recruitDate.start)
              : status === 'recruiting' && targetEvent.recruitDate?.end
                ? diffDay(targetEvent.recruitDate.end)
                : null;

          if (status === 'recruiting') {
            return {
              visible: true,
              dday,
              ddayLabel: '접수 마감까지',
              ddayClass: 'text-emerald-500',
              mode: targetEvent.formUrl ? 'link' : 'disabled',
              label: targetEvent.formUrl ? '접수하기' : '접수 링크 준비 중',
              buttonClass: targetEvent.formUrl
                ? 'flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-blue-600 text-white text-sm font-black hover:bg-blue-700 transition-colors'
                : 'w-full py-3 rounded-xl bg-slate-100 text-slate-400 text-sm font-black cursor-not-allowed',
            };
          }

          if (status === 'before-recruit') {
            return {
              visible: true,
              dday,
              ddayLabel: '접수 시작까지',
              ddayClass: 'text-amber-500',
              mode: 'disabled',
              label: '접수 예정',
              buttonClass: 'w-full py-3 rounded-xl bg-slate-100 text-slate-400 text-sm font-black cursor-not-allowed',
            };
          }

          if (status === 'today-upcoming') {
            return {
              visible: true,
              dday: null,
              ddayLabel: '',
              ddayClass: '',
              mode: 'disabled',
              label: `오늘 ${targetEvent.eventDate.startTime} 시작`,
              buttonClass: 'w-full py-3 rounded-xl bg-slate-100 text-slate-400 text-sm font-black cursor-not-allowed',
            };
          }

          if (status === 'today-ongoing') {
            return {
              visible: true,
              dday: null,
              ddayLabel: '',
              ddayClass: '',
              mode: 'disabled',
              label: '행사 진행 중',
              buttonClass: 'w-full py-3 rounded-xl bg-blue-50 text-blue-400 text-sm font-black cursor-not-allowed',
            };
          }

          if (status === 'recruit-closed') {
            return {
              visible: true,
              dday: null,
              ddayLabel: '',
              ddayClass: '',
              mode: 'disabled',
              label: '접수 마감',
              buttonClass: 'w-full py-3 rounded-xl bg-slate-100 text-slate-400 text-sm font-black cursor-not-allowed',
            };
          }

          return {
            visible: false,
            dday: null,
            ddayLabel: '',
            ddayClass: '',
            mode: 'disabled',
            label: '',
            buttonClass: '',
          };
        };

        const getTabState = (targetEvent, status) => ({
          notices: true,
          fee: isRecruitSoon(targetEvent, status) || ['recruiting', 'recruit-closed', 'today-upcoming', 'today-ongoing', 'past'].includes(status),
          registrants: ['recruiting', 'recruit-closed', 'today-upcoming', 'today-ongoing', 'past'].includes(status),
          results: status === 'past',
          related: Boolean(relatedRecord.journalPath || relatedRecord.reviewPath),
        });

        const status = getStatus(eventData);
        const actionState = getActionState(eventData, status);
        const tabState = getTabState(eventData, status);

        const backLink = document.getElementById('event-back-link');
        const backLabel = document.getElementById('event-back-label');
        const from = new URLSearchParams(window.location.search).get('from');

        if (backLink && backLabel) {
          if (from === 'upcoming') {
            backLink.setAttribute('href', '/events/upcoming');
            backLabel.textContent = '올해 행사 일정';
          } else {
            backLink.setAttribute('href', '/events/archive');
            backLabel.textContent = '역대 행사';
          }
        }

        const actionSection = document.getElementById('event-action-section');
        const ddayRow = document.getElementById('event-dday');
        const ddayLabel = document.getElementById('event-dday-label');
        const ddayValue = document.getElementById('event-dday-value');
        const applyLink = document.getElementById('event-apply-link');
        const disabledButton = document.getElementById('event-action-disabled');

        if (actionSection && ddayRow && ddayLabel && ddayValue && applyLink && disabledButton) {
          actionSection.classList.toggle('hidden', !actionState.visible);

          if (actionState.dday === null) {
            ddayRow.classList.add('hidden');
            ddayLabel.textContent = '';
            ddayValue.textContent = '';
            ddayValue.className = 'font-bold';
          } else {
            ddayRow.classList.remove('hidden');
            ddayLabel.textContent = `${actionState.ddayLabel} `;
            ddayValue.textContent = actionState.dday === 0 ? 'D-day' : `D-${actionState.dday}`;
            ddayValue.className = `font-bold ${actionState.ddayClass}`;
          }

          if (actionState.mode === 'link') {
            applyLink.className = actionState.buttonClass;
            applyLink.classList.remove('hidden');
            disabledButton.className = 'hidden';
            disabledButton.textContent = '';
          } else {
            applyLink.className = 'hidden';
            disabledButton.className = actionState.visible ? actionState.buttonClass : 'hidden';
            disabledButton.textContent = actionState.label;
          }
        }

        const tabButtons = Array.from(document.querySelectorAll('[data-event-tab-button]'));
        const panels = Array.from(document.querySelectorAll('[data-event-panel]'));
        const visibleTabs = [];

        tabButtons.forEach((button) => {
          const tabId = button.getAttribute('data-tab-id');
          const enabled = tabId ? tabState[tabId] : false;
          button.classList.toggle('hidden', !enabled);
          if (enabled && tabId) {
            visibleTabs.push(tabId);
          }
        });

        let activeTab = visibleTabs.includes('notices') ? 'notices' : visibleTabs[0];

        const activateTab = (tabId) => {
          activeTab = tabId;

          tabButtons.forEach((button) => {
            const isActive = button.getAttribute('data-tab-id') === tabId;
            button.classList.toggle('text-blue-600', isActive);
            button.classList.toggle('border-blue-500', isActive);
            button.classList.toggle('text-slate-400', !isActive);
            button.classList.toggle('border-transparent', !isActive);
          });

          panels.forEach((panel) => {
            panel.classList.toggle('hidden', panel.getAttribute('data-event-panel') !== tabId);
          });
        };

        tabButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const tabId = button.getAttribute('data-tab-id');
            if (!tabId || button.classList.contains('hidden')) return;
            activateTab(tabId);
          });
        });

        if (activeTab) {
          activateTab(activeTab);
        }
      })();
    </script>
  )}
</SiteLayout>
