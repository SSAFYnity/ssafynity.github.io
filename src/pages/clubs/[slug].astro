---
import Card from '~/components/Card.astro'
import Container from '~/components/Container.astro'
import Kicker from '~/components/Kicker.astro'
import LucideIcon from '~/components/LucideIcon.astro'
import ResponsiveText from '~/components/ResponsiveText.astro'
import SiteLayout from '~/layouts/SiteLayout.astro'
import { allClubs } from '@/data/computed'
import { CLUB_CATEGORIES, MODE_CONFIG, type ModeKey } from '@/data/constants'
import { withBaseAsset } from '@/lib/asset'
import { formatClubSince } from '@/lib/utils'

export function getStaticPaths() {
  return allClubs.map((club) => ({
    params: { slug: club.slug },
  }))
}

const { slug } = Astro.params
const pathname = `/clubs/${slug}`
const club = allClubs.find((item) => item.slug === slug)

const contactIconMap = {
  apply: 'user-plus',
  direct: 'message-circle',
  kakao: 'message-circle',
  discord: 'message-circle',
  github: 'github',
  notion: 'file-text',
  link: 'link',
} as const

function fieldItems(value: string | string[]) {
  return Array.isArray(value) ? value : [value]
}
---

<SiteLayout
  pathname={pathname}
  title={club ? `${club.name} | SSAFYnity` : '동아리를 찾을 수 없습니다 | SSAFYnity'}
  description={club?.shortDesc ?? '요청한 동아리 정보를 찾을 수 없습니다.'}
>
  {!club ? (
    <div class="flex flex-col items-center justify-center min-h-[50vh] gap-4 text-center px-6">
      <p class="text-sm font-extrabold text-slate-700">동아리를 찾을 수 없습니다.</p>
      <p class="text-xs text-slate-400">주소를 확인하거나 목록으로 돌아가주세요.</p>
      <a
        href="/clubs"
        class="mt-2 px-5 py-2.5 rounded-xl bg-blue-600 text-white text-sm font-black hover:bg-blue-700 transition-colors"
      >
        전체 동아리 보기
      </a>
    </div>
  ) : (
    <div class="flex flex-col">
      <section class="bg-white pt-24 pb-10 lg:pt-28 lg:pb-14 border-b border-slate-100">
        <Container maxWidth="5xl">
          <a
            href="/clubs"
            class="inline-flex items-center gap-1.5 text-xs text-slate-400 hover:text-blue-500 transition-colors mb-8"
          >
            <LucideIcon name="arrow-left" size={13} className="shrink-0" />
            전체 동아리
          </a>
          <div class="astro-reveal flex flex-col gap-4">
            <span class="inline-flex w-fit items-center rounded-full bg-blue-50 px-3 py-1.5 text-[11px] font-black text-blue-600">
              {CLUB_CATEGORIES[club.category].label}
            </span>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight text-slate-900 leading-snug">
              {club.name}
            </h1>
            <p class="text-sm text-slate-500 leading-relaxed break-keep max-w-xl">
              {club.shortDesc}
            </p>
            <div class="flex flex-wrap gap-2 pt-1">
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-slate-100 text-xs text-slate-500">
                <LucideIcon name="calendar" size={11} className="shrink-0" />
                {formatClubSince(club.since)} 개설
              </span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-slate-100 text-xs text-slate-500">
                <LucideIcon name="users" size={11} className="shrink-0" />
                {club.memberCount}명
              </span>
              {club.modes?.map((mode) => (
                <span class={`px-3 py-1.5 rounded-full text-xs font-black ${MODE_CONFIG[mode as ModeKey].className}`}>
                  {MODE_CONFIG[mode as ModeKey].label}
                </span>
              ))}
            </div>
          </div>
        </Container>
      </section>

      <section class="bg-slate-50 pt-8 pb-14 lg:pt-10 lg:pb-16 border-b border-slate-100">
        <Container maxWidth="5xl">
          <div class="grid lg:grid-cols-[1fr_280px] gap-8 items-start">
            <div class="astro-reveal flex flex-col gap-6">
              <div class="flex flex-col gap-3">
                <Kicker className="text-[10px] font-black text-blue-600 uppercase tracking-widest">About</Kicker>
                <p class="text-sm text-slate-600 leading-relaxed break-keep text-pretty">
                  <ResponsiveText text={club.desc} newline="always" />
                </p>
                {club.keywords && club.keywords.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 pt-1">
                    {club.keywords.map((keyword) => (
                      <span class="px-2.5 py-1 rounded-full bg-slate-100 text-[11px] font-medium text-slate-400">
                        #{keyword}
                      </span>
                    ))}
                  </div>
                )}
              </div>

              {club.achievements && club.achievements.length > 0 && (
                <div class="flex flex-col gap-3">
                  <Kicker className="text-[10px] font-black text-blue-600 uppercase tracking-widest">Highlights</Kicker>
                  <div class="flex flex-col gap-2">
                    {club.achievements.map((item) => (
                      <div class="flex items-start gap-3">
                        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 shrink-0 mt-2"></span>
                        <p class="text-sm text-slate-600 leading-relaxed break-keep">{item}</p>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              <div class="flex flex-col gap-2">
                <Card className="bg-white rounded-2xl border border-slate-100 px-5 py-4 flex items-start gap-4">
                  <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
                    <LucideIcon name="activity" size={14} className="text-blue-600" />
                  </div>
                  <div class="flex flex-col gap-1">
                    <p class="text-xs font-black text-slate-700">활동 방식</p>
                    {Array.isArray(club.activities) ? (
                      <div class="flex flex-col gap-1.5 pt-0.5">
                        {fieldItems(club.activities).map((item) => (
                          <div class="flex items-start gap-2">
                            <span class="w-1 h-1 rounded-full bg-slate-400 shrink-0 mt-2"></span>
                            <p class="text-sm text-slate-500 leading-relaxed">{item}</p>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p class="text-sm text-slate-500 leading-relaxed">{club.activities}</p>
                    )}
                  </div>
                </Card>

                {club.schedule && (
                  <Card className="bg-white rounded-2xl border border-slate-100 px-5 py-4 flex items-start gap-4">
                    <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
                      <LucideIcon name="clock" size={14} className="text-blue-600" />
                    </div>
                    <div class="flex flex-col gap-1">
                      <p class="text-xs font-black text-slate-700">정기 일정</p>
                      {Array.isArray(club.schedule) ? (
                        <div class="flex flex-col gap-1.5 pt-0.5">
                          {fieldItems(club.schedule).map((item) => (
                            <div class="flex items-start gap-2">
                              <span class="w-1 h-1 rounded-full bg-slate-400 shrink-0 mt-2"></span>
                              <p class="text-sm text-slate-500 leading-relaxed">{item}</p>
                            </div>
                          ))}
                        </div>
                      ) : (
                        <p class="text-sm text-slate-500 leading-relaxed">{club.schedule}</p>
                      )}
                    </div>
                  </Card>
                )}

                {club.target && (
                  <Card className="bg-white rounded-2xl border border-slate-100 px-5 py-4 flex items-start gap-4">
                    <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
                      <LucideIcon name="user-check" size={14} className="text-blue-600" />
                    </div>
                    <div class="flex flex-col gap-1">
                      <p class="text-xs font-black text-slate-700">모집 대상</p>
                      {Array.isArray(club.target) ? (
                        <div class="flex flex-col gap-1.5 pt-0.5">
                          {fieldItems(club.target).map((item) => (
                            <div class="flex items-start gap-2">
                              <span class="w-1 h-1 rounded-full bg-slate-400 shrink-0 mt-2"></span>
                              <p class="text-sm text-slate-500 leading-relaxed">{item}</p>
                            </div>
                          ))}
                        </div>
                      ) : (
                        <p class="text-sm text-slate-500 leading-relaxed">{club.target}</p>
                      )}
                    </div>
                  </Card>
                )}

                {club.fee?.detail && (
                  <Card className="bg-white rounded-2xl border border-slate-100 px-5 py-4 flex items-start gap-4">
                    <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
                      <LucideIcon name="credit-card" size={14} className="text-blue-600" />
                    </div>
                    <div class="flex flex-col gap-1">
                      <p class="text-xs font-black text-slate-700">회비 안내</p>
                      {Array.isArray(club.fee.detail) ? (
                        <div class="flex flex-col gap-1.5 pt-0.5">
                          {fieldItems(club.fee.detail).map((item) => (
                            <div class="flex items-start gap-2">
                              <span class="w-1 h-1 rounded-full bg-slate-400 shrink-0 mt-2"></span>
                              <p class="text-sm text-slate-500 leading-relaxed">{item}</p>
                            </div>
                          ))}
                        </div>
                      ) : (
                        <p class="text-sm text-slate-500 leading-relaxed">{club.fee.detail}</p>
                      )}
                    </div>
                  </Card>
                )}
              </div>

              {club.joinProcess && club.joinProcess.length > 0 && (
                <div class="flex flex-col gap-3">
                  <Kicker className="text-[10px] font-black text-blue-600 uppercase tracking-widest">How to Join</Kicker>
                  <div class="flex flex-col gap-2">
                    {club.joinProcess.map((step, index) => (
                      <Card className="flex items-start gap-3 px-5 py-4">
                        <span class="w-5 h-5 rounded-full bg-blue-600 text-white text-[10px] font-black flex items-center justify-center shrink-0 mt-0.5">
                          {index + 1}
                        </span>
                        <p class="text-sm text-slate-500 leading-relaxed break-keep">{step}</p>
                      </Card>
                    ))}
                  </div>
                </div>
              )}

              {club.notes && club.notes.length > 0 && (
                <div class="flex flex-col gap-3">
                  <Kicker className="text-[10px] font-black text-blue-600 uppercase tracking-widest">Notice</Kicker>
                  <div class="flex flex-col gap-2">
                    {club.notes.map((note) => (
                      <Card className="flex items-start gap-3 px-5 py-4">
                        <span class="w-1.5 h-1.5 rounded-full bg-slate-400 shrink-0 mt-2"></span>
                        <p class="text-sm text-slate-600 leading-relaxed break-keep">{note}</p>
                      </Card>
                    ))}
                  </div>
                </div>
              )}
            </div>

            <div class="astro-reveal lg:sticky lg:top-24 flex flex-col gap-3" data-reveal-delay="120">
              <Card className="bg-white rounded-2xl border border-slate-100 p-6 flex flex-col gap-5">
                <div class="flex flex-col gap-3">
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-slate-400">개설 연도</span>
                    <span class="font-black text-slate-700">{formatClubSince(club.since)}</span>
                  </div>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-slate-400">멤버 수</span>
                    <span class="font-black text-slate-700">{club.memberCount}명</span>
                  </div>
                  {club.fee && (
                    <div class="flex items-center justify-between text-xs">
                      <span class="text-slate-400">회비</span>
                      <span class="font-black text-slate-700">{club.fee.summary}</span>
                    </div>
                  )}
                  {club.modes && club.modes.length > 0 && (
                    <div class="flex items-center justify-between text-xs gap-2">
                      <span class="text-slate-400 shrink-0">활동 형태</span>
                      <div class="flex flex-wrap justify-end gap-1">
                        {club.modes.map((mode) => (
                          <span class={`text-[10px] font-black px-2 py-0.5 rounded-full ${MODE_CONFIG[mode as ModeKey].className}`}>
                            {MODE_CONFIG[mode as ModeKey].label}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}
                  {club.region && (
                    <div class="flex items-center justify-between text-xs gap-3">
                      <span class="text-slate-400 shrink-0">활동 지역</span>
                      <span class="font-black text-slate-700 text-right">{club.region}</span>
                    </div>
                  )}
                </div>

                <div class="flex flex-col gap-2">
                  {club.contacts.map((contact, index) => {
                    const iconName = contact.icon ? contactIconMap[contact.icon] : 'external-link'
                    return (
                      <a
                        href={contact.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-track-event="click_club_contact_link"
                        data-track-params={JSON.stringify({
                          club_slug: club.slug,
                          club_name: club.name,
                          club_category: club.category,
                          contact_label: contact.label,
                          contact_type: contact.icon ?? 'external',
                          destination_url: contact.url,
                        })}
                        class={`w-full flex items-center justify-center gap-2 py-3 rounded-xl text-sm font-black transition-colors ${
                          index === 0
                            ? 'bg-blue-600 text-white hover:bg-blue-700'
                            : 'border border-blue-200 text-blue-600 hover:bg-blue-50'
                        }`}
                      >
                        {contact.label}
                        <LucideIcon name={iconName} size={14} />
                      </a>
                    )
                  })}
                </div>

                {club.links && club.links.length > 0 && (
                  <div class="flex flex-col gap-2 border-t border-slate-100 pt-4">
                    <p class="text-[10px] font-black text-slate-400 tracking-widest mb-0.5">Links</p>
                    {club.links.map((link) => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-track-event="click_club_external_link"
                        data-track-params={JSON.stringify({
                          club_slug: club.slug,
                          club_name: club.name,
                          club_category: club.category,
                          link_label: link.label,
                          destination_url: link.url,
                        })}
                        class="flex items-center justify-between text-xs px-3 py-2 rounded-xl border border-slate-100 text-slate-500 hover:border-blue-200 hover:text-blue-600 transition-colors"
                      >
                        {link.label}
                        <LucideIcon name="external-link" size={10} className="shrink-0 text-slate-300" />
                      </a>
                    ))}
                  </div>
                )}
              </Card>
            </div>
          </div>
        </Container>
      </section>

      {club.images.length > 0 && (
        <section class="bg-white pt-8 pb-14 lg:pt-10 lg:pb-16 border-b border-slate-100">
          <Container maxWidth="5xl" className="flex flex-col gap-5">
            <Kicker className="text-[10px] font-black text-blue-600 uppercase tracking-widest">Gallery</Kicker>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
              {club.images.map((src, index) => (
                <div class="astro-reveal aspect-square rounded-2xl overflow-hidden bg-slate-100" data-reveal-delay={String(index * 60)}>
                  <img
                    src={withBaseAsset(src)}
                    alt={`${club.name} 활동사진 ${index + 1}`}
                    class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-300"
                  />
                </div>
              ))}
            </div>
          </Container>
        </section>
      )}
    </div>
  )}
</SiteLayout>
