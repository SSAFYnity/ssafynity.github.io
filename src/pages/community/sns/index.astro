---
import Card from '~/components/Card.astro'
import Container from '~/components/Container.astro'
import HeroLabel from '~/components/HeroLabel.astro'
import Kicker from '~/components/Kicker.astro'
import LucideIcon from '~/components/LucideIcon.astro'
import SocialBrandIcon from '~/components/SocialBrandIcon.astro'
import SiteLayout from '~/layouts/SiteLayout.astro'
import { siteData } from '@/data/siteData'

const pathname = '/community/sns'

const iconNameMap = {
  kakao: 'kakao',
  instagram: 'instagram',
  linkedin: 'linkedin',
  github: 'github',
  gmail: 'gmail',
  discord: 'discord',
} as const

type Channel = (typeof siteData.sns)[number] & { ready: boolean }

type ChannelDetails = {
  summary: readonly string[]
  audience: readonly string[]
  howto: readonly string[]
}

const detailsByName: Record<string, ChannelDetails> = {
  '카카오톡 채널': {
    summary: ['행사·가입 안내 등 공지를 가장 빠르게 확인하는 채널입니다.', '간단한 문의/확인에 적합합니다.'],
    audience: ['동문회에 관심이 있는 누구든', '예비 동문회원 및 외부 참여자 모두'],
    howto: ['채널 추가 후 알림을 켜 주세요.', '중요한 문의나 긴 내용은 메일로 보내 주세요.'],
  },
  '카카오톡 오픈카톡': {
    summary: ['정회원을 위한 실시간 소통 채널입니다.', '정회원 공지·소통·선공개 및 투표에 활용됩니다.'],
    audience: ['동문회 운영진', '동문회 정회원'],
    howto: ['정회원 전환 후 안내 메일이 발송됩니다.', '공개 링크로 운영하지 않으며, 별도 안내를 통해서만 입장할 수 있습니다.'],
  },
  디스코드: {
    summary: ['관심사·주제별로 자유롭게 소통할 수 있는 커뮤니티 채널입니다.', '음성 채팅도 가능하며, 온라인 행사도 여기서 진행됩니다.'],
    audience: ['소통하고 싶은 누구나', '동문회원 및 외부 참여자 모두'],
    howto: ['외부 참여자가 이용할 수 있는 채널은 일부로 제한됩니다.', '역할(권한)에 따라 접근 가능한 채널이 달라집니다.'],
  },
  인스타그램: {
    summary: ['사진 중심으로 소식을 전하는 공식 SNS입니다.', '이벤트 안내와 공유에 적합합니다.'],
    audience: ['인스타그램을 이용하는 동문회 관심자', '동문회원 및 외부 참여자 모두'],
    howto: ['공식 채널을 팔로우해 주세요.', '게시글 및 스토리로 올라오는 여러 소식을 확인해 주세요.'],
  },
  링크드인: {
    summary: ['커리어 플랫폼 특성에 맞춰 동문회 성과를 중심으로 공유합니다.', '시니어 연사 모집 등 대외 모집 공지가 주로 올라옵니다.'],
    audience: ['링크드인을 이용하는 동문회 관심자', '동문회원 및 외부 참여자 모두'],
    howto: ['공식 채널을 팔로우해 주세요.', '게시글로 올라오는 소식을 확인해 주세요.'],
  },
  깃허브: {
    summary: ['동문회 공식 홈페이지 및 블로그를 운영하는 공간입니다.', '일부 이벤트/스터디 운영에 한정해 사용합니다.'],
    audience: ['(공식 사이트 및 블로그) 운영진만 가능', '(일부 이벤트/스터디 한정) 동문회원 JOIN 가능'],
    howto: ['운영 원칙에 따라 오픈소스 기여(이슈/PR)는 받지 않습니다.', '이벤트/스터디 대상자에 한해 Member로 직접 초대해 드립니다.'],
  },
}

function isReadyUrl(url: string) {
  return url.trim().length > 0 && !url.includes('[업데이트 필요]')
}

function displayUrl(url: string) {
  return url.startsWith('mailto:') ? url.replace('mailto:', '') : url
}

function mailAddress(url: string) {
  const displayed = displayUrl(url)
  const queryIndex = displayed.indexOf('?')
  return queryIndex >= 0 ? displayed.slice(0, queryIndex) : displayed
}

function mailtoWithTemplate(url: string, subject: string, bodyLines: readonly string[]) {
  const address = mailAddress(url)
  const params = new URLSearchParams()
  if (subject.trim().length > 0) params.set('subject', subject)
  if (bodyLines.length > 0) params.set('body', bodyLines.join('\n'))
  const query = params.toString()
  return `mailto:${address}${query ? `?${query}` : ''}`
}

const allChannels: Channel[] = siteData.sns.map((channel) => ({
  ...channel,
  ready: isReadyUrl(channel.url),
}))

const mainEmail = allChannels.find((channel) => channel.name === 'Gmail')
const extEmail = allChannels.find((channel) => channel.name === 'Gmail(대외협력)')
const snsChannels = allChannels.filter((channel) => channel.icon !== 'gmail')
const defaultSelectedName =
  snsChannels.find((channel) => channel.ready || channel.name === '카카오톡 오픈카톡')?.name ??
  snsChannels[0]?.name ??
  ''
---

<SiteLayout pathname={pathname}>
  <div class="flex flex-col">
    <section class="bg-white pt-20 sm:pt-24 pb-12 sm:pb-14 lg:pt-28 lg:pb-20 border-b border-slate-100">
      <Container maxWidth="5xl">
        <div class="astro-reveal">
          <HeroLabel>Community</HeroLabel>
          <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight leading-[1.2] text-slate-900 mb-2">
            공식 채널
          </h1>
          <p class="text-xl md:text-2xl font-black text-blue-600 mb-4">SSAFYnity Official Channels</p>
          <p class="text-sm text-slate-500 leading-relaxed break-keep text-pretty max-w-2xl">
            문의·소식·커뮤니티 참여는 아래의 공식 채널을 이용해 주세요.
          </p>
        </div>
      </Container>
    </section>

    <section class="bg-slate-50 py-12 sm:py-14 lg:py-20">
      <Container maxWidth="5xl" className="flex flex-col gap-10 sm:gap-12">
        <div class="astro-reveal" id="mail-section">
          <Kicker className="text-blue-600 mb-4">Mail</Kicker>
          <p class="text-sm text-slate-500 leading-relaxed break-keep mb-5">
            공식 메일과 대외협력(제휴·후원) 메일은 용도가 다릅니다. 목적에 맞는 메일로 문의해 주세요.
          </p>
          <div class="grid sm:grid-cols-2 gap-4">
            {mainEmail?.ready && (
              <Card className="p-6 flex flex-col gap-4 hover:border-slate-200 hover:shadow-sm transition-all">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center shrink-0">
                    <LucideIcon name="mail" size={20} className="text-blue-600" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="text-[10px] font-black px-2 py-1 rounded-full bg-blue-50 text-blue-600">공식</span>
                      <p class="text-sm font-extrabold text-slate-900">공지/행사 확정 · 일반 문의</p>
                    </div>
                    <p class="text-xs text-slate-500 break-all">{mailAddress(mainEmail.url)}</p>
                  </div>
                </div>

                <div class="flex flex-col gap-2">
                  {[
                    '공지 및 행사 확정 관련 메일을 발송/수신합니다.',
                    '문의가 애매하면 공식 메일로 보내 주세요. 담당에게 연결해 드립니다.',
                  ].map((item) => (
                    <div class="flex items-start gap-2 text-sm text-slate-600 leading-relaxed break-keep">
                      <span class="text-slate-500 font-black mt-0.5">·</span>
                      <span>{item}</span>
                    </div>
                  ))}
                </div>

                <div class="mt-auto pt-4 border-t border-slate-100 flex flex-col gap-2">
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                    <a
                      href={mailtoWithTemplate(mainEmail.url, '[SSAFYnity 공식 문의]', [
                        '문의 목적: ',
                        '이름/기수: ',
                        '연락처: ',
                        '내용: ',
                        '첨부/링크: ',
                      ])}
                      data-track-event="click_sns_link"
                      data-track-params={JSON.stringify({
                        channel_name: mainEmail.name,
                        channel_type: 'email',
                        cta_label: '메일 작성',
                        destination_url: mailAddress(mainEmail.url),
                      })}
                      class="w-full inline-flex items-center justify-center gap-2 text-xs font-black px-3.5 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 transition-colors"
                    >
                      메일 작성 <LucideIcon name="external-link" size={14} />
                    </a>
                    <button
                      type="button"
                      data-copy-button
                      data-copy-text={mailAddress(mainEmail.url)}
                      data-copy-default="주소 복사"
                      data-copy-success="복사됨"
                      class="w-full inline-flex items-center justify-center gap-2 text-xs font-black px-3 py-2 rounded-xl border border-slate-200 bg-white text-slate-700 hover:bg-slate-50 transition-colors"
                    >
                      <span data-copy-icon-default><LucideIcon name="copy" size={14} /></span>
                      <span data-copy-icon-success class="hidden"><LucideIcon name="check" size={14} /></span>
                      <span data-copy-label>주소 복사</span>
                    </button>
                  </div>
                  <p class="text-[11px] text-slate-400 leading-relaxed break-keep">
                    메일 앱이 열리지 않으면 주소 복사로 웹메일에서 보내 주세요.
                  </p>
                </div>
              </Card>
            )}

            {extEmail?.ready && (
              <Card className="p-6 flex flex-col gap-4 hover:border-slate-200 hover:shadow-sm transition-all">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center shrink-0">
                    <LucideIcon name="mail" size={20} className="text-blue-600" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="text-[10px] font-black px-2 py-1 rounded-full bg-slate-100 text-slate-700">대외협력</span>
                      <p class="text-sm font-extrabold text-slate-900">제휴/후원 문의</p>
                    </div>
                    <p class="text-xs text-slate-500 break-all">{mailAddress(extEmail.url)}</p>
                  </div>
                </div>

                <div class="flex flex-col gap-2">
                  {[
                    '대외협력(제휴·후원) 문의 전용 메일입니다.',
                    '제안서/자료 첨부가 필요한 문의에 적합합니다.',
                  ].map((item) => (
                    <div class="flex items-start gap-2 text-sm text-slate-600 leading-relaxed break-keep">
                      <span class="text-slate-500 font-black mt-0.5">·</span>
                      <span>{item}</span>
                    </div>
                  ))}
                </div>

                <div class="mt-auto pt-4 border-t border-slate-100 flex flex-col gap-2">
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                    <a
                      href={mailtoWithTemplate(extEmail.url, '[SSAFYnity 제휴/후원 문의]', [
                        '회사/기관명: ',
                        '담당자/직함: ',
                        '연락처: ',
                        '제안 요약: ',
                        '첨부/링크: ',
                        '희망 일정: ',
                      ])}
                      data-track-event="click_sns_link"
                      data-track-params={JSON.stringify({
                        channel_name: extEmail.name,
                        channel_type: 'email',
                        cta_label: '메일 작성',
                        destination_url: mailAddress(extEmail.url),
                      })}
                      class="w-full inline-flex items-center justify-center gap-2 text-xs font-black px-3.5 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 transition-colors"
                    >
                      메일 작성 <LucideIcon name="external-link" size={14} />
                    </a>
                    <button
                      type="button"
                      data-copy-button
                      data-copy-text={mailAddress(extEmail.url)}
                      data-copy-default="주소 복사"
                      data-copy-success="복사됨"
                      class="w-full inline-flex items-center justify-center gap-2 text-xs font-black px-3 py-2 rounded-xl border border-slate-200 bg-white text-slate-700 hover:bg-slate-50 transition-colors"
                    >
                      <span data-copy-icon-default><LucideIcon name="copy" size={14} /></span>
                      <span data-copy-icon-success class="hidden"><LucideIcon name="check" size={14} /></span>
                      <span data-copy-label>주소 복사</span>
                    </button>
                  </div>
                  <p class="text-[11px] text-slate-400 leading-relaxed break-keep">
                    메일 앱이 열리지 않으면 주소 복사로 웹메일에서 보내 주세요.
                  </p>
                </div>
              </Card>
            )}
          </div>
        </div>

        <div class="astro-reveal" data-reveal-delay="60">
          <Kicker className="text-blue-600 mb-4">SNS</Kicker>
          <p class="text-sm text-slate-500 leading-relaxed break-keep mb-5">
            모든 행사 및 공지사항은 각 공식 채널에 동일하게 업로드됩니다. 편한 SNS를 활용해 주세요.
          </p>

          <Card className="p-0 overflow-hidden border-slate-200 shadow-sm">
            <div
              role="tablist"
              aria-label="SNS 채널"
              class="flex items-end gap-1 overflow-x-auto no-scrollbar bg-slate-50/70 px-2 pt-2 shadow-[inset_0_-1px_0_0_rgba(148,163,184,0.35)]"
            >
              {snsChannels.map((channel) => {
                const isSelected = channel.name === defaultSelectedName
                const isRestricted = channel.name === '카카오톡 오픈카톡'
                const idSafe = encodeURIComponent(channel.name)

                return (
                  <button
                    id={`sns-tab-${idSafe}`}
                    type="button"
                    role="tab"
                    aria-selected={isSelected ? 'true' : 'false'}
                    aria-controls={`sns-panel-${idSafe}`}
                    tabindex={isSelected ? '0' : '-1'}
                    data-sns-tab={channel.name}
                    class={`relative -mb-px inline-flex items-center gap-2 px-3 py-2 text-xs font-black whitespace-nowrap border transition-colors outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50 ${
                      isSelected
                        ? 'z-10 bg-white text-slate-900 border-slate-200 border-b-white shadow-sm rounded-t-xl rounded-b-none'
                        : channel.ready || isRestricted
                          ? 'bg-transparent text-slate-600 border-transparent hover:bg-white/70 hover:text-slate-900 rounded-xl'
                          : 'bg-transparent text-slate-400 border-transparent opacity-70 hover:bg-white/50 hover:text-slate-500 rounded-xl'
                    }`}
                  >
                    <span
                      class={`w-6 h-6 rounded-lg flex items-center justify-center shrink-0 border border-slate-200 bg-white ${
                        isSelected ? 'shadow-sm' : 'opacity-90'
                      }`}
                    >
                      <SocialBrandIcon
                        name={iconNameMap[channel.icon as keyof typeof iconNameMap]}
                        size={14}
                        className="shrink-0"
                        style={`color:${channel.color}`}
                      />
                    </span>
                    <span>{channel.name}</span>
                  </button>
                )
              })}
            </div>

            {snsChannels.map((channel) => {
              const details = detailsByName[channel.name] ?? {
                summary: ['내용 준비 중입니다.'],
                audience: ['내용 준비 중입니다.'],
                howto: ['내용 준비 중입니다.'],
              }
              const idSafe = encodeURIComponent(channel.name)
              const isSelected = channel.name === defaultSelectedName

              return (
                <div
                  role="tabpanel"
                  id={`sns-panel-${idSafe}`}
                  aria-labelledby={`sns-tab-${idSafe}`}
                  data-sns-panel={channel.name}
                  class:list={['p-5', !isSelected && 'hidden']}
                >
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {([
                      { title: '요약', items: details.summary },
                      { title: '대상', items: details.audience },
                      { title: '방법', items: details.howto },
                    ] as const).map((section) => (
                      <Card className="p-5">
                        <p class="text-xs font-black text-slate-900 mb-3">{section.title}</p>
                        <div class="flex flex-col gap-2">
                          {section.items.map((item) => (
                            <div class="flex items-start gap-2 text-sm text-slate-600 leading-relaxed break-keep">
                              <span class="text-blue-600 font-black mt-0.5">·</span>
                              <span>{item}</span>
                            </div>
                          ))}
                        </div>
                      </Card>
                    ))}

                    <Card className="p-5">
                      <p class="text-xs font-black text-slate-900 mb-3">링크</p>

                      {channel.name === '카카오톡 오픈카톡' ? (
                        <div class="flex flex-col gap-3">
                          <p class="text-sm text-slate-600 leading-relaxed break-keep">
                            오픈카톡 링크는 공개하지 않으며, 정회원에게만 별도로 안내됩니다.
                          </p>
                          {mainEmail?.ready ? (
                            <a
                              href={mailtoWithTemplate(mainEmail.url, '[SSAFYnity 오픈카톡 안내 요청]', [
                                '이름/기수: ',
                                '정회원 여부(예/아니오): ',
                                '문의 내용: ',
                              ])}
                              data-track-event="click_sns_link"
                              data-track-params={JSON.stringify({
                                channel_name: channel.name,
                                channel_type: channel.icon,
                                cta_label: '공식 메일로 문의',
                                destination_url: mailAddress(mainEmail.url),
                              })}
                              class="w-full inline-flex items-center justify-center gap-2 text-xs font-black px-3.5 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 transition-colors"
                            >
                              공식 메일로 문의 <LucideIcon name="external-link" size={14} />
                            </a>
                          ) : (
                            <a
                              href="#mail-section"
                              class="w-full inline-flex items-center justify-center gap-2 text-xs font-black px-3.5 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 transition-colors"
                            >
                              메일 섹션으로 이동 <LucideIcon name="external-link" size={14} />
                            </a>
                          )}
                        </div>
                      ) : channel.ready ? (
                        <div class="flex flex-col gap-3">
                          <div class="grid gap-2">
                            <a
                              href={channel.url}
                              target={channel.url.startsWith('http') ? '_blank' : undefined}
                              rel={channel.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                              data-track-event="click_sns_link"
                              data-track-params={JSON.stringify({
                                channel_name: channel.name,
                                channel_type: channel.icon,
                                cta_label: '바로가기',
                                destination_url: channel.url,
                              })}
                              class="w-full inline-flex items-center justify-center gap-2 text-xs font-black px-3.5 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 transition-colors"
                            >
                              바로가기 <LucideIcon name="external-link" size={14} />
                            </a>
                            <button
                              type="button"
                              data-copy-button
                              data-copy-text={channel.url}
                              data-copy-default="링크 복사"
                              data-copy-success="복사됨"
                              class="w-full inline-flex items-center justify-center gap-2 text-xs font-black px-3 py-2 rounded-xl border border-slate-200 bg-white text-slate-700 hover:bg-slate-50 transition-colors"
                            >
                              <span data-copy-icon-default><LucideIcon name="copy" size={14} /></span>
                              <span data-copy-icon-success class="hidden"><LucideIcon name="check" size={14} /></span>
                              <span data-copy-label>링크 복사</span>
                            </button>
                          </div>

                          {displayUrl(channel.url).trim().length > 0 && (
                            <p class="text-[11px] text-slate-400 break-all">{displayUrl(channel.url)}</p>
                          )}
                        </div>
                      ) : (
                        <p class="text-sm text-slate-500 leading-relaxed break-keep">링크 정보를 준비 중입니다.</p>
                      )}
                    </Card>
                  </div>
                </div>
              )
            })}
          </Card>
        </div>

        <div class="astro-reveal" data-reveal-delay="80">
          <Kicker className="text-blue-600 mb-4">Safety</Kicker>
          <Card className="p-6">
            <p class="text-sm font-extrabold text-slate-900 mb-2">사칭/피싱 주의</p>
            <p class="text-sm text-slate-500 leading-relaxed break-keep">
              공식 채널은 이 페이지에 안내된 링크만 사용해 주세요. 행사 참가비·후원 요청 등 금전 안내는 반드시 공식 문의 채널로 재확인해 주세요.
            </p>
            <div class="my-4 h-px bg-slate-200/70"></div>
            <p class="text-sm font-extrabold text-slate-900 mb-2">커뮤니티 신고</p>
            <p class="text-sm text-slate-500 leading-relaxed break-keep">
              커뮤니티 내 금전 요구, 욕설·비방, 음란물 등 부적절한 행위는 신고해 주세요. 내용이 확인된 경우 사전 통보 없이 강제 탈퇴 처리될 예정입니다.
            </p>
          </Card>
        </div>
      </Container>
    </section>
  </div>

  <script is:inline>
    (() => {
      const tabButtons = Array.from(document.querySelectorAll('[data-sns-tab]'));
      const panels = Array.from(document.querySelectorAll('[data-sns-panel]'));

      const setSelectedTab = (name) => {
        tabButtons.forEach((button) => {
          const isSelected = button.getAttribute('data-sns-tab') === name;
          button.setAttribute('aria-selected', isSelected ? 'true' : 'false');
          button.setAttribute('tabindex', isSelected ? '0' : '-1');
          button.classList.toggle('z-10', isSelected);
          button.classList.toggle('bg-white', isSelected);
          button.classList.toggle('text-slate-900', isSelected);
          button.classList.toggle('border-slate-200', isSelected);
          button.classList.toggle('border-b-white', isSelected);
          button.classList.toggle('shadow-sm', isSelected);
          button.classList.toggle('rounded-t-xl', isSelected);
          button.classList.toggle('rounded-b-none', isSelected);
          button.classList.toggle('bg-transparent', !isSelected);
          button.classList.toggle('text-slate-600', !isSelected);
          button.classList.toggle('border-transparent', !isSelected);
          button.classList.toggle('rounded-xl', !isSelected);
        });

        panels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.getAttribute('data-sns-panel') !== name);
        });
      };

      tabButtons.forEach((button, index) => {
        button.addEventListener('click', () => {
          const name = button.getAttribute('data-sns-tab');
          if (!name) return;
          setSelectedTab(name);
        });

        button.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
          event.preventDefault();

          const currentIndex = index;
          const lastIndex = tabButtons.length - 1;
          const nextIndex =
            event.key === 'Home'
              ? 0
              : event.key === 'End'
                ? lastIndex
                : event.key === 'ArrowLeft'
                  ? (currentIndex - 1 + tabButtons.length) % tabButtons.length
                  : (currentIndex + 1) % tabButtons.length;

          const nextButton = tabButtons[nextIndex];
          const name = nextButton?.getAttribute('data-sns-tab');
          if (!nextButton || !name) return;
          setSelectedTab(name);
          nextButton.focus();
        });
      });

      const copyButtons = Array.from(document.querySelectorAll('[data-copy-button]'));
      copyButtons.forEach((button) => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-copy-text');
          if (!text) return;

          try {
            await navigator.clipboard.writeText(text);
          } catch {
            return;
          }

          const label = button.querySelector('[data-copy-label]');
          const defaultIcon = button.querySelector('[data-copy-icon-default]');
          const successIcon = button.querySelector('[data-copy-icon-success]');
          const defaultText = button.getAttribute('data-copy-default') ?? '복사';
          const successText = button.getAttribute('data-copy-success') ?? '복사됨';

          button.classList.add('border-blue-200', 'bg-blue-50', 'text-blue-700');
          button.classList.remove('border-slate-200', 'bg-white', 'text-slate-700');
          label.textContent = successText;
          defaultIcon?.classList.add('hidden');
          successIcon?.classList.remove('hidden');

          window.clearTimeout(Number(button.getAttribute('data-copy-timeout') || '0'));
          const timeout = window.setTimeout(() => {
            button.classList.remove('border-blue-200', 'bg-blue-50', 'text-blue-700');
            button.classList.add('border-slate-200', 'bg-white', 'text-slate-700');
            label.textContent = defaultText;
            defaultIcon?.classList.remove('hidden');
            successIcon?.classList.add('hidden');
          }, 1200);

          button.setAttribute('data-copy-timeout', String(timeout));
        });
      });
    })();
  </script>
</SiteLayout>
